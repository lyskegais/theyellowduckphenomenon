<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} — {% endif %}{{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="stylesheet" href="{{ "/assets/css/style.css" | url }}">
  {% if bodyClass == "home" %}
  <link rel="stylesheet" href="{{ "/assets/css/home.css" | url }}">
  {% endif %}
  {% if bodyClass == "thesis" %}
  <link rel="stylesheet" href="{{ "/assets/css/thesis.css" | url }}">
  <link rel="stylesheet" href="{{ "/assets/css/ducks.css" | url }}">
  {% endif %}
  {% if bodyClass == "project" %}
  <link rel="stylesheet" href="{{ "/assets/css/project.css" | url }}">
  {% endif %}
</head>
<body class="{{ bodyClass or 'page' }}">

  {% block content %}{% endblock %}

  <script src="{{ "/assets/js/main.js" | url }}"></script>
  {% if bodyClass == "thesis" %}
  <script src="{{ "/assets/js/thesis.js" | url }}"></script>
  {% endif %}
</body>
</html>
